<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="4dp"
    app:cardBackgroundColor="#1a1a1a"
    app:cardCornerRadius="6dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Transaction Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/transactionTypeText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="💰 Balance Added"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#ffffff" />

            <TextView
                android:id="@+id/amountText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+500 Atoms"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#4CAF50" />

        </LinearLayout>

        <!-- Balance Change -->
        <TextView
            android:id="@+id/balanceChangeText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="1000 → 1500 Atoms"
            android:textSize="12sp"
            android:textColor="#cccccc"
            android:layout_marginTop="4dp" />

        <!-- Transaction Details -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="8dp">

            <TextView
                android:id="@+id/dateText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Jan 15, 2024 14:30:25"
                android:textSize="11sp"
                android:textColor="#888888" />

            <TextView
                android:id="@+id/performedByText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="By: Admin"
                android:textSize="11sp"
                android:textColor="#888888"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/cardUidText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Card: A1B2C3D4"
                android:textSize="11sp"
                android:textColor="#888888"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/descriptionText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Balance added"
                android:textSize="11sp"
                android:textColor="#888888"
                android:layout_marginTop="2dp" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>